# joplin-cli configuration — environment variables.
#
# NOTE: the CLI does NOT auto-load this file. Copy it to `.env`, fill in your
# values, then load it into your shell before running commands:
#
#   set -a; source .env; set +a
#   joplin-cli ping
#
# Alternatively pass values per-command with --token / --base-url, or store the
# token encrypted with `joplin-cli login`.

# Joplin Web Clipper token (Joplin: Tools -> Options -> Web Clipper -> Advanced -> copy token)
JOPLIN_TOKEN=your_joplin_web_clipper_token_here

# Base URL of the Joplin Web Clipper service (default shown)
JOPLIN_BASE_URL=http://localhost:41184

# Optional HTTP tuning (defaults shown)
JOPLIN_TIMEOUT_SECONDS=30
JOPLIN_HTTP_RETRIES=3
JOPLIN_HTTP_RETRY_BACKOFF_SECONDS=1.0
